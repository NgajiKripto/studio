generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  FREE
  GLOW_BASIC
  GLOW_PRO
  GLOW_STAR
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum SkinType {
  OILY
  DRY
  COMBINATION
  NORMAL
  SENSITIVE
}

enum SkinTone {
  FAIR_COOL
  FAIR_WARM
  FAIR_NEUTRAL
  LIGHT_COOL
  LIGHT_WARM
  LIGHT_NEUTRAL
  MEDIUM_COOL
  MEDIUM_WARM
  MEDIUM_NEUTRAL
  TAN_COOL
  TAN_WARM
  TAN_NEUTRAL
  DEEP_COOL
  DEEP_WARM
  DEEP_NEUTRAL
}

enum FaceShape {
  OVAL
  ROUND
  SQUARE
  HEART
  DIAMOND
  OBLONG
}

// ==================== USER MODEL ====================

model User {
  id                 String             @id @default(cuid())
  name               String
  username           String             @unique
  email              String             @unique
  password           String?
  image              String?
  avatarUrl          String?
  bio                String?
  role               UserRole           @default(FREE)
  affiliateCode      String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  saldo              Float              @default(0)
  skinType           SkinType?
  skinTone           SkinTone?
  faceShape          FaceShape?
  profileViews       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  accounts           Account[]
  recommendedProducts UserRecommendedProduct[]
  affiliateClicks    AffiliateClick[]

  @@index([role])
  @@index([skinType, skinTone, faceShape])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ==================== GLOW CIRCLE MODELS ====================

model UserRecommendedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  note      String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model AffiliateClick {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  visitorIp     String?
  referrer      String?
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ==================== PRODUCT MODEL ====================

model Product {
  id              String             @id @default(cuid())
  name            String
  brand           String
  category        String
  description     String
  priceEstimate   String
  affiliateUrl    String
  imageUrl        String
  muaVerdict      String
  skinTypes       ProductSkinType[]
  skinTones       ProductSkinTone[]
  faceShapes      ProductFaceShape[]
  recommendedBy   UserRecommendedProduct[]
  affiliateClicks AffiliateClick[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// ==================== QUIZ RESULT MODEL ====================

model QuizResult {
  id           String   @id @default(cuid())
  sessionId    String
  skinType     String
  skinTone     String
  faceShape    String
  activity     String   @default("INDOOR")
  consentGiven Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([consentGiven])
  @@index([createdAt])
}

model ProductSkinType {
  id        String  @id @default(cuid())
  productId String
  skinType  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSkinTone {
  id        String  @id @default(cuid())
  productId String
  skinTone  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFaceShape {
  id        String  @id @default(cuid())
  productId String
  faceShape String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
